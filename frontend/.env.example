# Server-only: where Next.js proxies `/api/*` (see app/api/[...path]/route.ts).
DJANGO_API_PROXY_URL=http://127.0.0.1:8000

# Optional: call Django from the browser directly (requires CORS on Django).
# NEXT_PUBLIC_DJANGO_API_URL=http://127.0.0.1:8000

# The app calls Django at /api/v1/... (see src/lib/api.ts API_V1_PREFIX).

# Backend: leave `SUPABASE_JWT_SECRET` empty for email sign-in via POST /api/v1/auth/dev-identify.
# For admin dashboard API lists, set DEV_USER_ROLE=admin when JWT is off.

# Supabase (browser client + middleware). Required for /login, /register, /dashboard JWT flow.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: show Google OAuth on login/register when enabled in Supabase dashboard.
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

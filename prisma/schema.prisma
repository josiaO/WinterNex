generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  payments  Payment[]
  websites  Website[]
  domains   Domain[]
  services  Service[]
}

model Domain {
  id           String      @id @default(cuid())
  domainName   String      @unique
  tld          String
  status       String      @default("available")
  registeredAt DateTime?
  expiresAt    DateTime?
  locked       Boolean     @default(false)
  autoRenew    Boolean     @default(false)
  whoisPrivacy Boolean     @default(false)
  transferCode String?
  userId       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user       User?       @relation(fields: [userId], references: [id])
  orders     Order[]
  dnsRecords DnsRecord[]
  websites   Website[]
  services   Service[]
}

model DnsRecord {
  id        String   @id @default(cuid())
  domainId  String
  type      String
  name      String
  value     String
  priority  Int?
  ttl       Int      @default(3600)
  createdAt DateTime @default(now())

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  userId      String
  domainId    String?
  type        String
  status      String   @default("pending")
  amount      Float
  currency    String   @default("KES")
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User    @relation(fields: [userId], references: [id])
  domain   Domain? @relation(fields: [domainId], references: [id])
  payments Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  orderId       String
  method        String
  status        String   @default("pending")
  amount        Float
  currency      String   @default("KES")
  transactionId String?
  phoneNumber   String?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])
}

model Website {
  id           String    @id @default(cuid())
  userId       String
  businessName String
  category     String?
  description  String?
  htmlContent  String?
  theme        String    @default("modern")
  status       String    @default("draft")
  domainId     String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  domain Domain? @relation(fields: [domainId], references: [id])
}

model Service {
  id          String    @id @default(cuid())
  name        String
  type        String    // 'hosting', 'email', 'ssl'
  status      String    @default("active")
  userId      String
  domainId    String?
  plan        String
  price       Float
  currency    String    @default("KES")
  startsAt    DateTime  @default(now())
  expiresAt   DateTime?
  metadata    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  domain Domain? @relation(fields: [domainId], references: [id])
}
